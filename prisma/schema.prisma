generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum ReaderRole {
  READER
  ADMIN
}

enum ConnectionStatus {
  DISCONNECTED
  CONNECTED
  EXPIRED
  ERROR
}

enum ReceiptDraftStatus {
  LOCAL_DRAFT
  REMOTE_DRAFT
  SEALED
  ERROR
}

model User {
  id                  String                 @id @default(cuid())
  name                String?
  email               String?                @unique
  emailVerified       DateTime?
  image               String?
  accounts            Account[]
  sessions            Session[]
  readerProfile       ReaderProfile?
  getReceiptsConnection GetReceiptsConnection?
  readingReceiptDrafts ReadingReceiptDraft[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model ReaderProfile {
  id                  String                @id @default(cuid())
  userId              String                @unique
  displayName         String
  readerSlug          String                @unique
  role                ReaderRole            @default(READER)
  lastReadSlug        String?
  lastReadAt          DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmarks           Bookmark[]
  highlights          Highlight[]
  notes               Note[]
  readingProgress     ReadingProgress[]
  readingReceiptDrafts ReadingReceiptDraft[]
}

model Bookmark {
  id            String        @id @default(cuid())
  readerProfileId String
  sectionSlug   String
  label         String
  excerpt       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  readerProfile ReaderProfile @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)

  @@unique([readerProfileId, sectionSlug])
  @@index([readerProfileId, createdAt])
}

model Highlight {
  id            String        @id @default(cuid())
  readerProfileId String
  sectionSlug   String
  sectionTitle  String
  blockId       String
  startOffset   Int
  endOffset     Int
  quote         String
  excerpt       String
  color         String        @default("paper-gold")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  readerProfile ReaderProfile @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)

  @@index([readerProfileId, sectionSlug])
  @@index([readerProfileId, blockId])
}

model Note {
  id            String        @id @default(cuid())
  readerProfileId String
  sectionSlug   String
  sectionTitle  String
  blockId       String
  startOffset   Int
  endOffset     Int
  quote         String
  excerpt       String
  noteText      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  readerProfile ReaderProfile @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)

  @@index([readerProfileId, sectionSlug])
  @@index([readerProfileId, blockId])
}

model ReadingProgress {
  id              String        @id @default(cuid())
  readerProfileId String
  sectionSlug     String
  progressPercent Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  readerProfile   ReaderProfile @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)

  @@unique([readerProfileId])
}

model GetReceiptsConnection {
  id                   String           @id @default(cuid())
  userId               String           @unique
  getReceiptsUserId    String?
  appSlug              String           @default("assembled-reality")
  accessTokenEncrypted String?
  tokenType            String?
  scopes               String[]
  expiresAt            DateTime?
  status               ConnectionStatus @default(DISCONNECTED)
  lastError            String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReadingReceiptDraft {
  id                  String             @id @default(cuid())
  userId              String
  readerProfileId     String
  getReceiptsReceiptId String?
  status              ReceiptDraftStatus @default(LOCAL_DRAFT)
  title               String?
  sourceSections      String[]
  sourceMarkIds       String[]
  payload             Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  readerProfile       ReaderProfile      @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([readerProfileId, createdAt])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
