generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum ReaderRole {
  READER
  ADMIN
}

enum ConnectionStatus {
  DISCONNECTED
  CONNECTED
  EXPIRED
  ERROR
}

enum ReceiptDraftStatus {
  LOCAL_DRAFT
  REMOTE_DRAFT
  SEALED
  ERROR
}

enum ReceiptStance {
  TENTATIVE
  WORKING
  CONFIDENT
}

enum ConversationMessageRole {
  USER
  ASSISTANT
}

enum EvidenceOrigin {
  READER
  SEVEN
}

enum EvidenceSourceType {
  PASSAGE
  HIGHLIGHT
  NOTE
  CITATION
}

enum ReaderDocumentFormat {
  MARKDOWN
  DOC
  DOCX
  PDF
}

enum ReaderVoiceProvider {
  OPENAI
  ELEVENLABS
  DEVICE
}

enum ReaderPlaybackScope {
  FLOW
  SECTION
  SELECTION
  MESSAGE
}

enum ListeningSessionStatus {
  IDLE
  ACTIVE
  PAUSED
}

enum ReaderProjectDocumentRole {
  SOURCE
  ASSEMBLY
}

enum ReaderSourceAssetKind {
  IMAGE
  LINK
  AUDIO
}

model User {
  id                  String                 @id @default(cuid())
  name                String?
  email               String?                @unique
  emailVerified       DateTime?
  image               String?
  accounts            Account[]
  sessions            Session[]
  readerProfile       ReaderProfile?
  getReceiptsConnection GetReceiptsConnection?
  readingReceiptDrafts ReadingReceiptDraft[]
  readerConversationThreads ReaderConversationThread[]
  readerEvidenceSets   ReaderEvidenceSet[]
  readerDocuments      ReaderDocument[]
  readerSourceAssets   ReaderSourceAsset[]
  readerProjects       ReaderProject[]
  readerListeningSessions ReaderListeningSession[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model ReaderProfile {
  id                  String                @id @default(cuid())
  userId              String                @unique
  displayName         String
  readerSlug          String                @unique
  role                ReaderRole            @default(READER)
  lastReadSlug        String?
  lastReadAt          DateTime?
  disclaimerAcceptedAt DateTime?
  preferredVoiceProvider ReaderVoiceProvider?
  preferredVoiceId    String?
  preferredListeningRate Float              @default(1)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmarks           Bookmark[]
  highlights          Highlight[]
  notes               Note[]
  readingProgress     ReadingProgress[]
  readingReceiptDrafts ReadingReceiptDraft[]
  readerConversationThreads ReaderConversationThread[]
  readerEvidenceSets   ReaderEvidenceSet[]
  readerListeningSessions ReaderListeningSession[]
}

model Bookmark {
  id            String        @id @default(cuid())
  readerProfileId String
  documentKey   String        @default("assembled-reality-v07-final")
  sectionSlug   String
  label         String
  excerpt       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  readerProfile ReaderProfile @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)

  @@unique([readerProfileId, documentKey, sectionSlug])
  @@index([readerProfileId, documentKey, createdAt])
}

model Highlight {
  id            String        @id @default(cuid())
  readerProfileId String
  documentKey   String        @default("assembled-reality-v07-final")
  sectionSlug   String
  sectionTitle  String
  blockId       String
  startOffset   Int
  endOffset     Int
  quote         String
  excerpt       String
  color         String        @default("paper-gold")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  readerProfile ReaderProfile @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)

  @@index([readerProfileId, documentKey, sectionSlug])
  @@index([readerProfileId, documentKey, blockId])
}

model Note {
  id            String        @id @default(cuid())
  readerProfileId String
  documentKey   String        @default("assembled-reality-v07-final")
  sectionSlug   String
  sectionTitle  String
  blockId       String
  startOffset   Int
  endOffset     Int
  quote         String
  excerpt       String
  noteText      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  readerProfile ReaderProfile @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)

  @@index([readerProfileId, documentKey, sectionSlug])
  @@index([readerProfileId, documentKey, blockId])
}

model ReadingProgress {
  id              String        @id @default(cuid())
  readerProfileId String
  documentKey     String        @default("assembled-reality-v07-final")
  sectionSlug     String
  progressPercent Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  readerProfile   ReaderProfile @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)

  @@unique([readerProfileId, documentKey])
  @@index([readerProfileId, updatedAt])
}

model ReaderDocument {
  id              String               @id @default(cuid())
  userId          String
  documentKey     String               @unique
  title           String
  subtitle        String?
  format          ReaderDocumentFormat @default(MARKDOWN)
  mimeType        String?
  originalFilename String?
  contentMarkdown String               @db.Text
  wordCount       Int                  @default(0)
  sectionCount    Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceAssets    ReaderSourceAsset[]

  @@index([userId, updatedAt])
}

model ReaderSourceAsset {
  id               String                @id
  userId           String
  documentKey      String
  projectKey       String?
  kind             ReaderSourceAssetKind @default(IMAGE)
  blobUrl          String?
  blobPath         String?
  sourceUrl        String?
  canonicalUrl     String?
  label            String?
  mimeType         String?
  originalFilename String?
  width            Int?
  height           Int?
  durationMs       Int?
  byteSize         Int?
  sha256           String?
  metadataJson     Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  document         ReaderDocument        @relation(fields: [documentKey], references: [documentKey], onDelete: Cascade)

  @@unique([userId, documentKey, kind])
  @@index([documentKey])
  @@index([userId, createdAt])
}

model ReaderProject {
  id                        String                  @id @default(cuid())
  userId                    String
  projectKey                String
  title                     String
  subtitle                  String?
  currentAssemblyDocumentKey String?
  metadataJson              Json?
  isPinned                  Boolean                 @default(false)
  isArchived                Boolean                 @default(false)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  user                      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents                 ReaderProjectDocument[]
  readingReceiptDrafts      ReadingReceiptDraft[]

  @@unique([userId, projectKey])
  @@index([userId, updatedAt])
  @@index([userId, isArchived, updatedAt])
}

model ReaderProjectDocument {
  id         String                    @id @default(cuid())
  projectId  String
  documentKey String
  role       ReaderProjectDocumentRole @default(SOURCE)
  position   Int                       @default(0)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  project    ReaderProject             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, documentKey])
  @@index([projectId, role, position])
  @@index([documentKey])
}

model GetReceiptsConnection {
  id                   String           @id @default(cuid())
  userId               String           @unique
  getReceiptsUserId    String?
  appSlug              String           @default("assembled-reality")
  accessTokenEncrypted String?
  tokenType            String?
  scopes               String[]
  expiresAt            DateTime?
  status               ConnectionStatus @default(DISCONNECTED)
  lastError            String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReadingReceiptDraft {
  id                  String             @id @default(cuid())
  userId              String
  readerProfileId     String
  projectId           String?
  documentKey         String             @default("assembled-reality-v07-final")
  conversationThreadId String?
  getReceiptsReceiptId String?
  status              ReceiptDraftStatus @default(LOCAL_DRAFT)
  title               String?
  interpretation      String?            @db.Text
  implications        String?            @db.Text
  stance              ReceiptStance      @default(TENTATIVE)
  linkedEvidenceItemIds String[]
  linkedMessageIds    String[]
  sourceSections      String[]
  sourceMarkIds       String[]
  payload             Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  readerProfile       ReaderProfile      @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)
  project             ReaderProject?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  conversationThread  ReaderConversationThread? @relation(fields: [conversationThreadId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([readerProfileId, createdAt])
  @@index([projectId, createdAt])
  @@index([documentKey, createdAt])
  @@index([conversationThreadId])
}

model ReaderConversationThread {
  id             String                     @id @default(cuid())
  userId         String
  readerProfileId String
  documentKey    String
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  readerProfile  ReaderProfile              @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)
  messages       ReaderConversationMessage[]
  readingReceiptDrafts ReadingReceiptDraft[]

  @@unique([readerProfileId, documentKey])
  @@index([userId, documentKey])
}

model ReaderConversationMessage {
  id         String                   @id @default(cuid())
  threadId   String
  role       ConversationMessageRole
  content    String                   @db.Text
  citations  Json?
  createdAt  DateTime                 @default(now())
  thread     ReaderConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  evidenceItems ReaderEvidenceItem[]  @relation("EvidenceSourceMessage")

  @@index([threadId, createdAt])
}

model ReaderEvidenceSet {
  id             String              @id @default(cuid())
  userId         String
  readerProfileId String
  documentKey    String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  readerProfile  ReaderProfile       @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)
  items          ReaderEvidenceItem[]

  @@unique([readerProfileId, documentKey])
  @@index([userId, documentKey])
}

model ReaderEvidenceItem {
  id             String                  @id @default(cuid())
  evidenceSetId  String
  origin         EvidenceOrigin
  sourceType     EvidenceSourceType
  sectionSlug    String
  sectionTitle   String
  blockId        String?
  startOffset    Int?
  endOffset      Int?
  quote          String                  @db.Text
  excerpt        String                  @db.Text
  noteText       String?                 @db.Text
  sourceMarkId   String?
  sourceMessageId String?
  sourceCitationId String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  evidenceSet    ReaderEvidenceSet       @relation(fields: [evidenceSetId], references: [id], onDelete: Cascade)
  sourceMessage  ReaderConversationMessage? @relation("EvidenceSourceMessage", fields: [sourceMessageId], references: [id], onDelete: SetNull)

  @@index([evidenceSetId, createdAt])
  @@index([sourceMarkId])
  @@index([sourceMessageId])
}

model ReaderListeningSession {
  id              String                 @id @default(cuid())
  userId          String
  readerProfileId String
  documentKey     String
  mode            ReaderPlaybackScope    @default(FLOW)
  scopeStartNodeId String?
  scopeEndNodeId  String?
  activeNodeId    String?
  activeSectionSlug String?
  nodeOffsetMs    Int                    @default(0)
  rate            Float                  @default(1)
  provider        ReaderVoiceProvider?
  voiceId         String?
  status          ListeningSessionStatus @default(IDLE)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  readerProfile   ReaderProfile          @relation(fields: [readerProfileId], references: [id], onDelete: Cascade)

  @@unique([readerProfileId, documentKey])
  @@index([userId, documentKey])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
