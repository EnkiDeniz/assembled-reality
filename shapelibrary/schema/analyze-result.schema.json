{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalyzeResult",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "runId",
        "resultType",
        "shapeIds",
        "granularity",
        "gate",
        "reads",
        "ambiguities",
        "discriminatingTest",
        "requiredReceipts",
        "confidence",
        "confidenceSource",
        "operatorRead"
      ],
      "properties": {
        "runId": { "type": "string" },
        "resultType": {
          "type": "string",
          "enum": ["primitive_match", "assembly_match", "candidate_primitive", "candidate_assembly", "rejection"]
        },
        "shapeIds": { "type": "array", "items": { "type": "string" } },
        "granularity": { "type": "string", "enum": ["primitive", "assembly", "unknown"] },
        "assemblyClass": {
          "type": "string",
          "enum": ["combinable", "path_dependent", "developmental_embodied"]
        },
        "gate": { "type": "object" },
        "reads": { "type": "object" },
        "ambiguities": { "type": "array", "items": { "type": "string" } },
        "discriminatingTest": {
          "type": "object",
          "required": ["observable", "expectedOutcomeA", "expectedOutcomeB", "timeWindow"],
          "properties": {
            "observable": { "type": "string" },
            "expectedOutcomeA": { "type": "string" },
            "expectedOutcomeB": { "type": "string" },
            "timeWindow": { "type": "string" }
          }
        },
        "requiredReceipts": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number" },
        "confidenceSource": { "type": "string", "enum": ["convergence", "heuristic", "single_run"] },
        "candidateId": { "type": ["string", "null"] },
        "mainGap": { "type": "string" },
        "nextLawfulMove": { "type": "string" },
        "receiptCondition": {
          "type": "object",
          "required": ["receiptType", "validWhen"],
          "properties": {
            "receiptType": { "type": "string" },
            "validWhen": { "type": "string" }
          }
        },
        "possibleDisconfirmation": { "type": "string" },
        "intentLayerCheck": { "type": "object" },
        "matchBasis": { "type": ["string", "null"] },
        "nearMiss": {
          "type": ["object", "null"],
          "properties": {
            "shapeId": { "type": "string" },
            "score": { "type": "number" }
          }
        },
        "kernel": { "type": "object" },
        "crossDomain": { "type": "object" },
        "isMythDerived": { "type": "boolean" },
        "maturation": {
          "type": "object",
          "properties": {
            "requiredStages": { "type": "array", "items": { "type": "string" } },
            "nonImportableProperties": { "type": "array", "items": { "type": "string" } },
            "gate": { "type": "object" }
          }
        },
        "operatorRead": {
          "type": "object",
          "required": [
            "wallLine",
            "whatToPingNow",
            "whatWouldCountAsRealReturn",
            "howThisReadCouldBeWrong",
            "toneClass",
            "closureLanguageAllowed"
          ],
          "properties": {
            "wallLine": { "type": "string", "minLength": 1, "maxLength": 220 },
            "whatToPingNow": { "type": "string", "minLength": 1, "maxLength": 220 },
            "whatWouldCountAsRealReturn": { "type": "string", "minLength": 1, "maxLength": 240 },
            "howThisReadCouldBeWrong": { "type": "string", "minLength": 1, "maxLength": 240 },
            "toneClass": { "type": "string", "enum": ["pathology", "gate", "topology", "behavioral"] },
            "closureLanguageAllowed": { "type": "boolean" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": [
        "runId",
        "status",
        "granularity",
        "assemblyClass",
        "maturationBlockers",
        "mainGap",
        "nextLawfulMove",
        "receiptCondition",
        "possibleDisconfirmation",
        "requiredReceipts",
        "operatorRead"
      ],
      "properties": {
        "runId": { "type": "string" },
        "status": { "type": "string", "const": "not_sealable_yet" },
        "granularity": { "type": "string", "enum": ["primitive", "assembly", "unknown"] },
        "assemblyClass": {
          "type": "string",
          "enum": ["combinable", "path_dependent", "developmental_embodied"]
        },
        "intentLayerCheck": { "type": "object" },
        "maturationBlockers": { "type": "array", "items": { "type": "string" } },
        "mainGap": { "type": "string" },
        "nextLawfulMove": { "type": "string" },
        "receiptCondition": {
          "type": "object",
          "required": ["receiptType", "validWhen"],
          "properties": {
            "receiptType": { "type": "string" },
            "validWhen": { "type": "string" }
          }
        },
        "possibleDisconfirmation": { "type": "string" },
        "requiredReceipts": { "type": "array", "items": { "type": "string" } },
        "maturation": { "type": "object" },
        "operatorRead": {
          "type": "object",
          "required": [
            "wallLine",
            "whatToPingNow",
            "whatWouldCountAsRealReturn",
            "howThisReadCouldBeWrong",
            "toneClass",
            "closureLanguageAllowed"
          ],
          "properties": {
            "wallLine": { "type": "string", "minLength": 1, "maxLength": 220 },
            "whatToPingNow": { "type": "string", "minLength": 1, "maxLength": 220 },
            "whatWouldCountAsRealReturn": { "type": "string", "minLength": 1, "maxLength": 240 },
            "howThisReadCouldBeWrong": { "type": "string", "minLength": 1, "maxLength": 240 },
            "toneClass": { "type": "string", "enum": ["pathology", "gate", "topology", "behavioral"] },
            "closureLanguageAllowed": { "type": "boolean" }
          }
        }
      }
    }
  ]
}
